{
  "name": "folio-book-library",
  "version": "1.0.0",
  "description": "Folio - Personal Book Library Web App",
  "main": "index.js",
  "scripts": {
    "dev": "npm run dev --workspace=frontend",
    "dev:full": "concurrently \"npm run dev --workspace=backend\" \"npm run dev --workspace=frontend\"",
    "install:all": "npm install && npm install --workspace=backend && npm install --workspace=frontend",
    "build": "npm run build --workspace=frontend",
    "preview": "npm run preview --workspace=frontend"
  },
  "workspaces": [
    "backend",
    "frontend"
  ],
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
